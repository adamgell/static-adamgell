---
interface Props {
  title: string;
  description?: string;
  keywords?: string[];
}

const {
  title,
  description = "Adam Gell — Tools, diagrams, and blog",
  keywords = [],
} =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <Fragment set:html={`<style>
      .prose-code-styled code:not(pre code) {
        background-color: rgb(51 65 85) !important;
        border: 1px solid rgb(71 85 105) !important;
        padding: 0.15em 0.4em !important;
        border-radius: 0.25rem !important;
      }
      .prose-code-styled code:not(pre code)::before,
      .prose-code-styled code:not(pre code)::after {
        content: none !important;
      }
    </style>`} />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 font-sans antialiased">
    <nav
      class="sticky top-0 z-50 border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-md"
    >
      <div
        class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <div class="flex items-center gap-1 text-sm">
          <a
            href="/"
            class="px-3 py-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800/60 transition-colors"
            >Home</a
          >
          <a
            href="/tools"
            class="px-3 py-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800/60 transition-colors"
            >Tools</a
          >
          <a
            href="/tools/cmtrace"
            class="px-3 py-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800/60 transition-colors"
            >CMTrace</a
          >
          <a
            href="/blog"
            class="px-3 py-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800/60 transition-colors"
            >Blog</a
          >
          <a
            href="https://github.com/adamgell"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-2 p-1.5 rounded-md text-slate-500 hover:text-white hover:bg-slate-800/60 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-slate-800 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-6 text-sm text-slate-500">
        &copy; {new Date().getFullYear()} Adam Gell
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

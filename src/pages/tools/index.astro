---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Tools & Resources — Adam Gell">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight mb-2">Tools & Resources</h1>
    <p class="text-slate-400 mb-12">
      Tools I've built and community resources for Intune, Autopilot, and modern device management.
    </p>

    <section class="mb-14">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-5">
        My Tools
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <a
          href="/tools/autopilot-flow"
          class="group block border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors"
        >
          <h3 class="text-base font-semibold mb-1 group-hover:text-white transition-colors">
            Autopilot Enrollment Flow
          </h3>
          <p class="text-sm text-slate-400">
            Interactive diagram showing the Windows Autopilot and Intune device enrollment process.
          </p>
        </a>
        <a
          href="/tools/silent-install"
          class="group block border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors"
        >
          <h3 class="text-base font-semibold mb-1 group-hover:text-white transition-colors">
            Silent Install Library
          </h3>
          <p class="text-sm text-slate-400">
            Searchable silent install &amp; uninstall commands for Windows apps, curated from Winget manifests.
          </p>
        </a>
        <a
          href="https://intunecommander.com"
          target="_blank"
          rel="noopener noreferrer"
          class="group block border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors"
        >
          <div class="flex items-center gap-2 mb-1">
            <h3 class="text-base font-semibold group-hover:text-white transition-colors">
              Intune Commander
            </h3>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-slate-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-4.5-6h6m0 0v6m0-6L9.75 14.25" /></svg>
          </div>
          <p class="text-sm text-slate-400">
            A powerful tool for managing and monitoring Microsoft Intune environments.
          </p>
        </a>
        <a
          href="https://github.com/adamgell/homelab-code/tree/main/cmtrace-open"
          target="_blank"
          rel="noopener noreferrer"
          class="group block border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors"
        >
          <div class="flex items-center gap-2 mb-1">
            <h3 class="text-base font-semibold group-hover:text-white transition-colors">
              CMTrace Open (CMTrace alterative)
            </h3>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-slate-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-4.5-6h6m0 0v6m0-6L9.75 14.25" /></svg>
          </div>
          <p class="text-sm text-slate-400">
            A modern, cross‑platform, Tauri‑powered log analyzer that leaves the original CMTrace in the dust.
          </p>
        </a>
      </div>
    </section>

    <section>
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-5">
        Community Resources
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <a
          href="https://intunesettings.app"
          target="_blank"
          rel="noopener noreferrer"
          class="group block border border-slate-800 rounded-lg p-5 hover:border-slate-600 transition-colors"
        >
          <div class="flex items-center gap-2 mb-1">
            <h3 class="text-base font-semibold group-hover:text-white transition-colors">
              Intune Settings
            </h3>
            <svg class="w-3.5 h-3.5 text-slate-600 group-hover:text-slate-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-4.5-6h6m0 0v6m0-6L9.75 14.25" /></svg>
          </div>
          <p class="text-sm text-slate-400">
            Browse and search all available Intune configuration settings in one place.
          </p>
        </a>

        
      </div>
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Adam Gell">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center gap-8 mb-12">
      <img src="/images/avatar.jpg" alt="Adam Gell" class="shrink-0 w-40 h-40 rounded-full object-cover border border-slate-700" />
      <div class="flex-1">
        <h1 class="text-4xl font-bold tracking-tight mb-4">
          Hey, I'm Adam
        </h1>
        <p class="text-lg text-slate-400 max-w-xl">
          I build tools and write about IT infrastructure, device management, and automation.
        </p>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 max-w-2xl">
      <a
        href="/tools"
        class="group block border border-slate-800 rounded-lg p-6 hover:border-slate-600 transition-colors"
      >
        <h2 class="text-lg font-semibold mb-2 group-hover:text-white transition-colors">
          Tools &amp; Diagrams
        </h2>
        <p class="text-sm text-slate-400">
          Interactive visualizations for IT workflows and device enrollment flows.
        </p>
      </a>

      <a
        href="/blog"
        class="group block border border-slate-800 rounded-lg p-6 hover:border-slate-600 transition-colors"
      >
        <h2 class="text-lg font-semibold mb-2 group-hover:text-white transition-colors">
          Blog
        </h2>
        <p class="text-sm text-slate-400">
          Posts on Intune, Autopilot, and modern device management.
        </p>
      </a>
    </div>
    <div class="mt-12">
      <p class="text-lg font-semibold text-slate-400 mb-4">Find me on the internet.</p>
      <div class="flex gap-3">
        <a
          href="https://github.com/adamgell"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-400 hover:text-white hover:border-slate-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/adamgell"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-400 hover:text-white hover:border-slate-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="https://twitter.com/adamgell"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-slate-800 rounded-lg px-4 py-2.5 text-sm text-slate-400 hover:text-white hover:border-slate-600 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Twitter
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

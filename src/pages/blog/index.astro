---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title="Blog — Adam Gell">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold tracking-tight mb-8">Blog</h1>

    {sortedPosts.length === 0 ? (
      <p class="text-zinc-400">Posts coming soon.</p>
    ) : (
      <ul class="space-y-6">
        {sortedPosts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="group block border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-colors"
            >
              <time class="text-xs text-zinc-500">
                {new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              <h2 class="text-lg font-semibold mt-1 group-hover:text-white transition-colors">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-sm text-zinc-400 mt-2">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
